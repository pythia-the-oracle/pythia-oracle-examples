{
  "name": "pythia-oracle-examples",
  "version": "1.0.0",
  "description": "Integration examples for Pythia — on-chain EMA, RSI, VWAP, Bollinger Bands via Chainlink",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:testnet": "hardhat run scripts/deploy.js --network amoy",
    "deploy:mainnet": "hardhat run scripts/deploy.js --network polygon",
    "deploy:events:testnet": "hardhat run scripts/deploy-events.js --network amoy",
    "deploy:events:mainnet": "hardhat run scripts/deploy-events.js --network polygon"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.22.0"
  },
  "dependencies": {
    "@chainlink/contracts": "^1.2.0",
    "dotenv": "^17.4.1"
  }
}
